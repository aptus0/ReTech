<Window x:Class="ReTechDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KobiX Sistem Yöneticisi" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#f97316"/> <!-- Orange 500 -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ea580c"/> <!-- Orange 600 -->
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#525252"/>
                    <Setter Property="Foreground" Value="#a3a3a3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#262626"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#171717" CornerRadius="16" BorderBrush="#262626" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <!-- Title Bar -->
            <Grid Height="40" VerticalAlignment="Top">
                <TextBlock Text="KobiX Masaüstü Başlatıcı" Foreground="#a3a3a3" VerticalAlignment="Center" Margin="20,0" FontFamily="Segoe UI" FontSize="12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button Content="—" Width="40" Height="40" Background="Transparent" Foreground="#a3a3a3" BorderThickness="0" Click="MinimizeButton_Click"/>
                    <Button Content="✕" Width="40" Height="40" Background="Transparent" Foreground="#a3a3a3" BorderThickness="0" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <!-- Logo PlaceHolder -->
                <Border Width="100" Height="100" Background="#262626" CornerRadius="20" Margin="0,0,0,30">
                    <TextBlock Text="KobiX" Foreground="#f97316" FontFamily="Segoe UI" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Hoş Geldiniz" Foreground="White" FontFamily="Segoe UI" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Servislerinizi başlatmak için aşağıdaki butonları kullanın." Foreground="#a3a3a3" FontFamily="Segoe UI" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,30" TextWrapping="Wrap" TextAlignment="Center"/>

                <Button x:Name="BtnStartApi" Content="▶ API &amp; Veritabanını Başlat" Style="{StaticResource ModernButton}" Click="BtnStartApi_Click"/>
                <Button x:Name="BtnStartPrinter" Content="🖨 Printer Servisini Başlat" Style="{StaticResource SecondaryButton}" Click="BtnStartPrinter_Click"/>
                <Button x:Name="BtnStartWebApp" Content="🌐 Web Uygulamasını Aç" Style="{StaticResource SecondaryButton}" Click="BtnStartWebApp_Click"/>
                
                <TextBlock x:Name="TxtStatus" Text="Durum: Bekliyor" Foreground="#10b981" FontFamily="Segoe UI" FontSize="12" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
            
            <!-- First Run Link -->
            <Button Content="Firma Kaydı / İlk Kurulum" Background="Transparent" Foreground="#f97316" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20" Cursor="Hand" Click="BtnFirstRun_Click"/>
        </Grid>
    </Border>
</Window>
