<Window x:Class="KobiXPrintAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KobiX Print Agent" Height="350" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="KobiX Print Agent" FontSize="24" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="Hedef Yazıcı veya Port Seçimi:" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbPrinters" Height="35" FontSize="14" Padding="5" />
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button x:Name="BtnStart" Content="API'yi Başlat" Width="120" Height="40" Background="#2563EB" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Click="BtnStart_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="BtnStop" Content="API'yi Durdur" Width="120" Height="40" Background="#DC2626" Foreground="White" FontWeight="Bold" IsEnabled="False" Click="BtnStop_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="Sistem Logları" FontWeight="SemiBold" Margin="0,0,0,10">
            <TextBox x:Name="TxtLogs" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#1E293B" Foreground="#38BDF8" FontFamily="Consolas" Padding="5" TextWrapping="Wrap" />
        </GroupBox>

        <StatusBar Grid.Row="3" Background="Transparent">
            <StatusBarItem>
                <TextBlock x:Name="LblStatus" Text="Durum: Bekleniyor..." Foreground="#64748B" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
